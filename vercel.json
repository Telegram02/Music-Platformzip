{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/caktus-portfolio run build",
  "outputDirectory": "artifacts/caktus-portfolio/dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}
