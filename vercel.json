{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/caktus-portfolio run build",
  "outputDirectory": "artifacts/caktus-portfolio/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
