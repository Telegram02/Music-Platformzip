{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @workspace/caktus-portfolio run build",
  "outputDirectory": "artifacts/caktus-portfolio/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
